generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  warning
  suspended
}

enum ItemStatus {
  available
  matching
  completed
  canceled
}

enum ItemCondition {
  new
  used_good
  used_bad
}

enum Campus {
  toyonaka
  suita
  minoh
}

enum TransactionStatus {
  proposing
  scheduled
  completed
  canceled
}

enum ProposalStatus {
  pending
  accepted
  rejected
}

enum CancellationStatus {
  /// Compatibility value from the old request/response flow. New immediate cancellations use accepted.
  pending
  /// Immediate cancellation has been executed.
  accepted
  /// Compatibility value from the old request/response flow.
  rejected
}

enum OfferStatus {
  pending
  accepted
  rejected
}

enum EvaluationType {
  good
  bad
  cancel
  no_show
}

enum NotificationType {
  action_required
  info
}

model User {
  id                String     @id @default(uuid()) @db.Uuid
  email             String     @unique
  nickname          String
  profile_image_url String?
  credit_score      Int        @default(100)
  status            UserStatus @default(active)
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  items             Item[]
  sales             Transaction[]      @relation("SellerTransactions")
  purchases         Transaction[]      @relation("BuyerTransactions")
  proposalsSent     ScheduleProposal[] @relation("SenderProposals")
  offersSent        PriceOffer[]       @relation("SenderOffers")
  messagesSent      Message[]          @relation("SenderMessages")
  cancellationsSent CancellationRequest[] @relation("RequesterCancellations")
  evaluationsTarget Evaluation[]       @relation("TargetEvaluations")
  evaluationsGiven  Evaluation[]       @relation("ReviewerEvaluations")
  reportsSubmitted  Report[]           @relation("ReporterReports")
  reportsReceived   Report[]           @relation("ReportedReports")
  notifications     Notification[]     @relation("ReceiverNotifications")
  actorNotifications Notification[]    @relation("ActorNotifications")

  @@map("users")
}

model Item {
  id          String        @id @default(uuid()) @db.Uuid
  seller_id   String        @db.Uuid
  seller      User          @relation(fields: [seller_id], references: [id])
  title       String
  author      String?       // 著者名（任意）
  description String?
  condition   ItemCondition @default(new)
  campus      Campus        @default(toyonaka)
  handoff_location String?
  category    String?
  price       Int           @default(0)
  status      ItemStatus    @default(available)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  images       ItemImage[]
  transactions Transaction[]

  @@map("items")
}

/// 参考書の画像（1出品につき最大5枚）
/// display_order: 0 が先頭（メイン画像）
model ItemImage {
  id            String   @id @default(uuid()) @db.Uuid
  item_id       String   @db.Uuid
  item          Item     @relation(fields: [item_id], references: [id], onDelete: Cascade)
  image_url     String
  display_order Int      @default(0)
  created_at    DateTime @default(now())

  @@map("item_images")
}

model Transaction {
  id               String            @id @default(uuid()) @db.Uuid
  item_id          String            @db.Uuid
  item             Item              @relation(fields: [item_id], references: [id])
  seller_id        String            @db.Uuid
  seller           User              @relation("SellerTransactions", fields: [seller_id], references: [id])
  buyer_id         String            @db.Uuid
  buyer            User              @relation("BuyerTransactions", fields: [buyer_id], references: [id])
  final_price      Int?
  status           TransactionStatus @default(proposing)
  meeting_datetime DateTime?
  meeting_place    String?
  seller_evaluated Boolean           @default(false)
  buyer_evaluated  Boolean           @default(false)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  proposals   ScheduleProposal[]
  priceOffers PriceOffer[]
  cancellations CancellationRequest[]
  messages    Message[]
  evaluations Evaluation[]
  reports     Report[]

  @@map("transactions")
}

model ScheduleProposal {
  id                String              @id @default(uuid()) @db.Uuid
  transaction_id    String              @db.Uuid
  transaction       Transaction         @relation(fields: [transaction_id], references: [id])
  sender_id         String              @db.Uuid
  sender            User                @relation("SenderProposals", fields: [sender_id], references: [id])
  status            ProposalStatus      @default(pending)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt

  candidates        ScheduleCandidate[]

  @@map("schedule_proposals")
}

/// 場所マスター：エリア（キャンパス単位で束ねる）
model LocationArea {
  id         String          @id @default(uuid()) @db.Uuid
  campus     String          // "豊中" | "吹田" | "箕面"
  name       String          // 例: "豊中キャンパス北部"
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  spots      LocationSpot[]

  @@map("location_areas")
}

/// 場所マスター：スポット（エリア内の具体的な待ち合わせポイント）
model LocationSpot {
  id                  String       @id @default(uuid()) @db.Uuid
  area_id             String       @db.Uuid
  area                LocationArea @relation(fields: [area_id], references: [id], onDelete: Cascade)
  name                String       // 例: "図書館前 時計台"
  reference_image_url String?      // すれ違い防止用の参考画像URL
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  @@map("location_spots")
}

/// 日程提案スロット（ScheduleProposal 1件につき最大5スロット）
model ScheduleCandidate {
  id                  String           @id @default(uuid()) @db.Uuid
  proposal_id         String           @db.Uuid
  proposal            ScheduleProposal @relation(fields: [proposal_id], references: [id], onDelete: Cascade)
  proposed_datetime   DateTime
  proposed_place      String           // 将来的に location_spot_id FK へ移行予定
  status              ProposalStatus   @default(pending)
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  @@map("schedule_candidates")
}


/// 価格交渉オファーモデル（Take it or Leave it 方式 ・ 最大3回）
model PriceOffer {
  id             String      @id @default(uuid()) @db.Uuid
  transaction_id String      @db.Uuid
  transaction    Transaction @relation(fields: [transaction_id], references: [id])
  sender_id      String      @db.Uuid
  sender         User        @relation("SenderOffers", fields: [sender_id], references: [id])
  price          Int
  status         OfferStatus @default(pending)
  offer_count    Int         // 1　3の整数。3回目は受信側に2択のみ表示
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  @@map("price_offers")
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  transaction_id String      @db.Uuid
  transaction    Transaction @relation(fields: [transaction_id], references: [id])
  sender_id      String      @db.Uuid
  sender         User        @relation("SenderMessages", fields: [sender_id], references: [id])
  content        String
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  @@map("messages")
}

model Evaluation {
  id             String         @id @default(uuid()) @db.Uuid
  transaction_id String         @db.Uuid
  transaction    Transaction    @relation(fields: [transaction_id], references: [id])
  target_user_id String         @db.Uuid
  target_user    User           @relation("TargetEvaluations", fields: [target_user_id], references: [id])
  reviewer_id    String?        @db.Uuid
  reviewer       User?          @relation("ReviewerEvaluations", fields: [reviewer_id], references: [id])
  score_change   Int
  type           EvaluationType
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  @@map("evaluations")
}

model Report {
  id               String      @id @default(uuid()) @db.Uuid
  transaction_id   String      @db.Uuid
  transaction      Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  reporter_id      String      @db.Uuid
  reporter         User        @relation("ReporterReports", fields: [reporter_id], references: [id], onDelete: Cascade)
  reported_user_id String      @db.Uuid
  reportedUser     User        @relation("ReportedReports", fields: [reported_user_id], references: [id], onDelete: Cascade)
  reason           String
  detail           String
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  @@unique([transaction_id, reporter_id], map: "reports_transaction_reporter_unique")
  @@map("reports")
}

model Notification {
  id             String           @id @default(uuid()) @db.Uuid
  user_id        String           @db.Uuid
  user           User             @relation("ReceiverNotifications", fields: [user_id], references: [id])
  actor_id       String?          @db.Uuid
  actor          User?            @relation("ActorNotifications", fields: [actor_id], references: [id])
  title          String
  type           NotificationType
  transaction_id String?          @db.Uuid
  is_read        Boolean          @default(false)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  @@map("notifications")
}

/// Immediate cancellation history.
/// TODO: After backend cancellation APIs stabilize, rename this to CancellationEvent/Cancellation
/// and replace CancellationStatus with an executed-style enum/value.
model CancellationRequest {
  id             String             @id @default(uuid()) @db.Uuid
  transaction_id String             @unique @db.Uuid
  transaction    Transaction        @relation(fields: [transaction_id], references: [id])
  requester_id   String             @db.Uuid
  requester      User               @relation("RequesterCancellations", fields: [requester_id], references: [id])
  reason         String?
  status         CancellationStatus @default(pending)
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt

  @@map("cancellation_requests")
}
